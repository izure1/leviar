{
  "name": "leviar",
  "version": "1.0.4",
  "description": "WebGL 2.5D rendering engine with parallax scrolling",
  "license": "MIT",
  "repository": "https://github.com/izure1/leviar",
  "author": {
    "email": "admin@izure.org",
    "name": "izure",
    "url": "https://izure.org"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "./dist/**/*"
  ],
  "scripts": {
    "build": "node ./build/build.mjs && tsc",
    "build:example": "node ./build/build.mjs --example",
    "dev": "node ./build/build.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/matter-js": "^0.20.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "matter-js": "^0.20.0",
    "ogl": "^1.0.11"
  }
}